///---\\\
:GRAPH ModalSplit_Car
:TITLE Modal Split Car
:X-AXIS Time
:X-MIN 2009
:X-MAX 2050
:SCALE
:VAR TR ModalSplit[car,internal]
:DATASET *
:LINE-WIDTH 1
:VAR TR ModalSplit Data[car,internal]
:DATASET *
:LINE-WIDTH 1
:VAR TR ModalSplit[car passenger,internal]
:DATASET *
:LINE-WIDTH 1
:VAR TR ModalSplit Data[car passenger,internal]
:DATASET *
:LINE-WIDTH 1

:GRAPH ModalSplitPerCT
:TITLE ModalSplitPerCT
:X-AXIS Time
:SCALE
:VAR TR ModalSplitPerCT[mode,traffic type,coping type]
:DATASET 
:LINE-WIDTH 1

:GRAPH ModalSplit_OD
:TITLE Modal Split Car Origin Dest
:X-AXIS Time
:SCALE
:VAR TR ModalSplit[car,origin destination]
:DATASET *
:LINE-WIDTH 1
:VAR TR ModalSplit Data[car,origin destination]
:DATASET *
:LINE-WIDTH 1
:VAR TR ModalSplit[car passenger,origin destination]
:DATASET *
:LINE-WIDTH 1
:VAR TR ModalSplit Data[car passenger,origin destination]
:DATASET *
:LINE-WIDTH 1

:GRAPH ModalSplit_PT
:TITLE Modal Split PT
:X-AXIS Time
:SCALE
:VAR TR ModalSplit[public transport,internal]
:DATASET *
:LINE-WIDTH 1
:VAR TR ModalSplit Data[public transport,internal]
:DATASET *
:LINE-WIDTH 1
:VAR TR ModalSplit[walk,internal]
:DATASET *
:LINE-WIDTH 1
:VAR TR ModalSplit Data[walk,internal]
:DATASET *
:LINE-WIDTH 1
:VAR TR ModalSplit[bicycle,internal]
:DATASET *
:LINE-WIDTH 1
:VAR TR ModalSplit Data[bicycle,internal]
:DATASET *
:LINE-WIDTH 1

:GRAPH ModalSplit_PT_OD
:TITLE Modal Split PT Origin Dest
:X-AXIS Time
:SCALE
:VAR TR ModalSplit[public transport,origin destination]
:DATASET *
:LINE-WIDTH 1
:VAR TR ModalSplit Data[public transport,origin destination]
:DATASET *
:LINE-WIDTH 1
:VAR TR ModalSplit[walk,origin destination]
:DATASET *
:LINE-WIDTH 1
:VAR TR ModalSplit Data[walk,origin destination]
:DATASET *
:LINE-WIDTH 1
:VAR TR ModalSplit[bicycle,origin destination]
:DATASET *
:LINE-WIDTH 1
:VAR TR ModalSplit Data[bicycle,origin destination]
:DATASET *
:LINE-WIDTH 1

:GRAPH modalSplt_Car_PIs
:TITLE Modal split - Car
:X-AXIS SimYear
:X-LABEL Year
:Y-DIV 5
:X-MIN 2020
:NO-LEGEND 4
:FONT Arial|20||0-0-0
:SCALE
:VAR TR ModalSplit[car,internal]|Reference / BAU
:Y-MIN 0
:Y-MAX 0.5
:DATASET Reference.vdfx
:LINE-COLOR 128-128-128
:LINE-WIDTH 2
:VAR TR ModalSplit[car,internal]|Parking Cost
:DATASET PI_parkingCost.vdfx
:LINE-COLOR 0-0-255
:LINE-WIDTH 2
:VAR TR ModalSplit[car,internal]|Area Toll gradual
:DATASET PI_areaToll.vdfx
:LINE-COLOR 255-128-0
:LINE-WIDTH 2
:VAR TR ModalSplit[car,internal]|Area Toll step
:DATASET PI_areaToll_mod.vdfx
:LINE-COLOR 255-128-0
:LINE-STYLE DASH
:LINE-WIDTH 2
:VAR TR ModalSplit[car,internal]|All Measures
:DATASET PI_all.vdfx
:LINE-COLOR 0-255-0
:LINE-WIDTH 2
:VAR TR ModalSplit[car,internal]|Urban greening
:DATASET PI_greening.vdfx
:LINE-COLOR 0-128-0
:LINE-WIDTH 2
:VAR TR ModalSplit[car,internal]|All + Change of CT
:DATASET mob9ct1.vdfx
:LINE-COLOR 0-255-0
:LINE-STYLE DASHDOT
:LINE-WIDTH 2

:GRAPH PIs
:TITLE Interventions (examples)
:X-AXIS SimYear
:X-LABEL Year
:Y-DIV 3
:X-MIN 2020
:NO-LEGEND 4
:FONT Arial|20||0-0-0
:SCALE
