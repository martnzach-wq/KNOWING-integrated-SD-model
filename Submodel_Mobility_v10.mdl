{UTF-8}
CTChange[coping type]=
	CopingTypesDistribution[coping type] -CopingTypeDistrOfPreviousTimestep[coping type]
	~	
	~		|

CopingTypeDistrOfPreviousTimestep[coping type]=
	DELAY FIXED(CopingTypesDistribution[coping type], TIME STEP, CopingTypesDistribution\
		[coping type])
	~	
	~		|

TR Trips[mode,short,traffic type,coping type]= INTEG (
	TR DemandChangeRate[mode,short,traffic type,coping type] + TR DemandIncreasePop[short\
		,traffic type,mode,coping type] - 
	SUM( TR ModeChangeRate[mode,mode2!,short,traffic type
	,coping type]) + TR ShorterTrips[mode,medium,short,traffic type,coping type] + TR DemandIncreaseCT\
		[mode,short,traffic type,coping type],
		TR InitialTrips[mode,short,traffic type] * CopingTypesDistribution[coping type]) ~~|
TR Trips[mode,medium,traffic type,coping type]= INTEG (
	TR DemandChangeRate[mode,medium,traffic type,coping type] + TR DemandIncreasePop[medium\
		,traffic type,mode,coping type
	] - SUM( TR ModeChangeRate[mode,mode2!,medium,traffic type
	,coping type]) + TR ShorterTrips[mode,long,medium,traffic type,coping type] - TR ShorterTrips\
		[mode,medium,short,traffic type,coping type] + TR DemandIncreaseCT[mode,medium,traffic type\
		,coping type],
		TR InitialTrips[mode,medium,traffic type] * CopingTypesDistribution[coping type]) ~~|
TR Trips[mode,long,traffic type,coping type]= INTEG (
	TR DemandChangeRate[mode,long,traffic type,coping type] + TR DemandIncreasePop[long,\
		traffic type,mode,coping type
	] - SUM( TR ModeChangeRate[mode,mode2!,long,traffic type
	,coping type]) - TR ShorterTrips[mode,long,medium,traffic type,coping type] + TR DemandIncreaseCT\
		[mode,long,traffic type,coping type],
		TR InitialTrips[mode,long,traffic type] * CopingTypesDistribution[coping type])
	~	 [0,?]
	~		|

TR TripsPerCT[coping type]=
	SUM(TR Trips[mode!,trip length!,traffic type!,coping type])
	~	
	~		|

TR DemandIncreaseCT[mode,trip length,traffic type,coping type]=
	TR Trips[mode,trip length,traffic type,coping type] *
	(CopingTypesDistribution[coping type] - CopingTypeDistrOfPreviousTimestep[coping type\
		]) /
	(CopingTypeDistrOfPreviousTimestep[coping type] +1e-05)
	~	
	~		|

TR dist publ Tr electr=
	SUM( TR TotalDistancePerModePerYearPerPerson[public transport,traffic type!])
	~	
	~		|

TR dist cars electr=
	SUM (TR TotalDistancePerModePerYearPerPerson[car,traffic type!]) * TR PercentageOfEVs\
		 / 100
	~	
	~		|

TR dist cars fuels=
	SUM (TR TotalDistancePerModePerYearPerPerson[car,traffic type!]) * (100 - TR PercentageOfEVs\
		) / 100
	~	
	~		|

TR dist other Tr=
	0
	~	
	~		|

TR EVChangeRate=
	(200-TR PercentageOfEVs) / 2 / 12 * 0.018 * TR PI EVAdoptionAdaptation * TR EVAdoptionAdaptation\
		 * TR Cal EVAdoptionAdaptation
	 *
	IF THEN ELSE(Time > 120, 1 , 0 )
	~	
	~		|

TR ModalSplit[mode, traffic type]=
	SUM( TR Trips[mode,trip length!,traffic type,coping type!] * TR InitialTripLength[traffic type\
		,trip length!]) / TR TotalDistanceTravelled[traffic type]
	~	
	~		|

TR TotalDistanceTravelled[traffic type]=
	SUM( TR Trips[mode!,trip length!,traffic type,coping type!] * TR InitialTripLength[traffic type\
		,trip length!])
	~	
	~		|

HB Population[traffic type]= INTEG (
	HB PopNetIncrease[traffic type],
		HB InitialPopulation[traffic type])
	~	
	~		|

TR PercentageOfEVs= INTEG (
	TR EVChangeRate,
		0)
	~	
	~		|

TR TotalDistancePerModePerYearPerPerson[mode,traffic type]=
	TR TotalDistanceTravelled[traffic type] * TR ModalSplit[mode,traffic type] * 365 / 
	HB Population[internal]
	~	
	~		|

SimYear=
	Time
	~	
	~	was:
		2009 + Time / 12
	|

TR CarCostsPerKm=
	TR CarCostsPerKmFuel * (1 - TR PercentageOfEVs/100) + TR CarCostsPerKmEV * TR PercentageOfEVs\
		/100
	~	
	~		|

TR PI EVAdoptionAdaptation=
	0
	~	 [0,2,0.2]
	~		|

TR CarCostsPerKmFuel:INTERPOLATE:
	~	
	~		|

TR Cal EVAdoptionAdaptation=
	1
	~	
	~		|

TR EVAdoptionAdaptation:INTERPOLATE:
	~	
	~		|

TR CarCostsPerKmEV:INTERPOLATE:
	~	
	~		|

TR Attractiveness[active modes,trip length,traffic type,coping type]=
	TR BaseAtttractiveness[active modes,trip length] + TR AttractivenessDistinction * TR AttractivenessProfile\
		[active modes
	,coping type] - CL Cooling degree days / 100 + PI StreetGreening * 2 +
	IF THEN ELSE(active modes = bicycle, TR PI CyclingAddedAttractiveness*TR CyclingAddedAttractiveness\
		*TR Cal CyclingAddedAttractiveness[traffic type], 0 ) ~~|
TR Attractiveness[public transport,trip length,traffic type,coping type]=
	TR BaseAtttractiveness[public transport,trip length] + TR AttractivenessDistinction \
		* TR AttractivenessProfile[public transport
	,coping type] - CL Cooling degree days / 200 + PI StreetGreening * 1 ~~|
TR Attractiveness[car modes,trip length,traffic type,coping type]=
	TR BaseAtttractiveness[car modes,trip length] + TR AttractivenessDistinction * TR AttractivenessProfile\
		[car modes,coping type
	] - PI StreetGreening * 2 +
	IF THEN ELSE( car modes = car passenger, TR PI CarPassengerAddedAttractiveness
	*TR CarPassengerAddedAttractiveness*TR Cal CarPassengerAddedAttractiveness[trip length\
		,traffic type], 0 )
	~	
	~	Assumption: CDD = 100 decreases average attractiveness for active modes by \
		1, for PT by 0.5
	|

TR PI CyclingAddedAttractiveness=
	0
	~	 [0,2,0.2]
	~		|

TR GeneralisedCost[mode,trip length,traffic type,coping type]=
	TR Cost[mode,trip length,traffic type,coping type] + TR TravelTime[mode,trip length,\
		traffic type] * TR ValueOfTime[coping type
	] - TR Attractiveness[mode,trip length,traffic type,coping type]
	~	
	~		|

TR Cal CyclingAddedAttractiveness[traffic type]=
	1
	~	
	~		|

TR PI PTTravelTimeAdaptation=
	0
	~	 [0,2,0.2]
	~		|

TR PI RoadPricing=
	0
	~	 [0,2,0.2]
	~		|

TR Cal AreaToll[trip length,traffic type,car modes]=
	1
	~	
	~		|

TR RoadPricing:INTERPOLATE:
	~	
	~		|

TR Cal CarPassengerAddedAttractiveness[trip length,traffic type]=
	1
	~	
	~		|

TR ModalSplitPerTripLength[mode,trip length,traffic type]=
	SUM( TR Trips[mode,trip length,traffic type,coping type!]) / 
	SUM( TR Trips[mode!,trip length,traffic type,coping type!])
	~	
	~		|

TR ModalSplit Data[mode,traffic type]:RAW::=
	SUM( TR Trips Data[mode,trip length!,traffic type] * TR InitialTripLength[traffic type\
		,trip length!]) / 
	SUM( TR Trips Data[mode!,trip length!,traffic type] * TR InitialTripLength[traffic type\
		,trip length!])
	~	
	~		|

TR Cost[car modes,trip length,traffic type,coping type]=
	(TR CarCostsPerKm + TR AdaptedRoadPricing[traffic type]) * TR InitialTripLength[traffic type\
		,trip length] + TR AdaptedParkingCost + TR AdaptedAreaToll[trip length
	,traffic type,car modes] ~~|
TR Cost[public transport,short,internal,coping type]=
	0 ~~|
TR Cost[bicycle,trip length,traffic type,coping type]=
	0 ~~|
TR Cost[walk,trip length,traffic type,coping type]=
	0 ~~|
TR Cost[public transport,medium,internal,coping type]=
	0 ~~|
TR Cost[public transport,long,internal,coping type]=
	0 ~~|
TR Cost[public transport,short,origin destination,coping type]=
	0.72 ~~|
TR Cost[public transport,medium, origin destination,coping type]=
	0.72 ~~|
TR Cost[public transport,long,origin destination,coping type]=
	0.72
	~	
	~		|

TR Cal RoadPricing[traffic type]=
	1
	~	
	~		|

TR PI DistanceAdaptation=
	0
	~	
	~		|

TR PI CarPassengerAddedAttractiveness=
	0
	~	 [0,2,0.2]
	~		|

TR Cal DistanceAdaptation[trip length,traffic type]=
	1
	~	
	~		|

TR AdaptedAreaToll[trip length,traffic type,car modes]=
	TR PI AreaToll * TR AreaToll * TR Cal AreaToll[trip length,traffic type,car modes]
	~	
	~		|

TR PTTravelTimeAdaptation:INTERPOLATE:
	~	
	~		|

TR CyclingAddedAttractiveness:INTERPOLATE:
	~	
	~		|

TR AdaptedRoadPricing[traffic type]=
	TR PI RoadPricing * TR RoadPricing * TR Cal RoadPricing[traffic type]
	~	
	~		|

TR Cal PTTravelTimeAdaptation[traffic type]=
	1
	~	
	~		|

TR DistanceAdaptation:LOOK FORWARD:
	~	
	~		|

TR ShorterTrips[mode,medium,short,traffic type,coping type]=
	TR PI DistanceAdaptation*TR DistanceAdaptation/10*TR Cal DistanceAdaptation[medium,traffic type\
		]*TR Trips[mode,medium,traffic type,coping type] ~~|
TR ShorterTrips[mode,long,medium,traffic type,coping type]=
	TR PI DistanceAdaptation*TR DistanceAdaptation/10*TR Cal DistanceAdaptation[long,traffic type\
		]*TR Trips[mode,long,traffic type,coping type]
	~	
	~		|

TR CarPassengerAddedAttractiveness:INTERPOLATE:
	~	
	~		|

TR TravelTime[mode,trip length,traffic type]=
	TR InitialTripLength[traffic type,trip length] / TR AverageSpeed[mode,traffic type,trip length\
		] +
	TR AccessTime[traffic type, mode] *
	IF THEN ELSE(mode = public transport, ((1-TR PI PTTravelTimeAdaptation) + TR PI PTTravelTimeAdaptation\
		*TR PTTravelTimeAdaptation*TR Cal PTTravelTimeAdaptation[traffic type]), 1)
	~	
	~		|

TR PI AreaToll=
	0
	~	 [0,2,0.2]
	~		|

TR AreaToll:INTERPOLATE:
	~	
	~		|

TR PI ParkingCostAdaptation=
	0
	~	 [0,2,0.2]
	~		|

TR ParkingCostAdaptation:INTERPOLATE:
	~	
	~		|

TR Cal ParkingCostAdaptation=
	1
	~	
	~		|

TR AdaptedParkingCost=
	TR ParkingCost * (1-TR PI ParkingCostAdaptation) +
	TR ParkingCost * TR PI ParkingCostAdaptation * TR ParkingCostAdaptation * TR Cal ParkingCostAdaptation
	~	
	~		|

TR PI CapacityAdaptation=
	0
	~	 [0,2,0.2]
	~		|

TR CapacityAdaptation:INTERPOLATE:
	~	
	~		|

TR InitialTotalTravelTime[traffic type]=
	SUM(TR Trips Data[mode!,trip length!,traffic type] * TR InitialTripLength[traffic type\
		,trip length!] / TR TravelSpeed Data[mode!,trip length!,traffic type]) / SUM(TR Trips Data\
		[mode!,trip length!,traffic type])
	~	
	~		|

ComparisonOfSpeed[mode,trip length,traffic type]=
	(TR TotalTravelSpeed[mode,trip length,traffic type] - TR TravelSpeed Data[mode,trip length\
		,traffic type]) /
	TR TravelSpeed Data[mode,trip length,traffic type]
	~	
	~		|

TR AverageSpeed["non-car modes", internal, trip length]=
	TR NonCarVelocity["non-car modes",trip length] ~~|
TR AverageSpeed[car modes, traffic type, trip length]=
	TR FreeCarVelocity[traffic type] * ( 1 - SUM(TR Trips[car,trip length!,traffic type!\
		,coping type!]) / TR AdaptedNetworkCapacity) ~~|
TR AverageSpeed["non-car modes", origin destination, trip length]=
	TR NonCarVelocity["non-car modes",trip length]
	~	
	~		|

TR ParkingCost=
	1.5
	~	
	~		|

TR InitialTravelSpeed[trip length,mode,internal]=
	GET DIRECT CONSTANTS( 'mob_inputs.csv', 'mob_inputs' , 'B10' ) ~~|
TR InitialTravelSpeed[trip length,mode,origin destination]=
	GET DIRECT CONSTANTS( 'mob_inputs.csv', 'mob_inputs' , 'B13' )
	~	
	~		|

TR Cal CapacityAdaptation=
	1
	~	
	~		|

TR TripsWeight[mode,trip length,traffic type]=
	1/ SQRT(TR TotalTrips[mode,trip length,traffic type]+1)
	~	
	~		|

TR AdaptedNetworkCapacity=
	TR NetworkCapacity * (1-TR PI CapacityAdaptation) + 
	TR NetworkCapacity * TR PI CapacityAdaptation * TR CapacityAdaptation * TR Cal CapacityAdaptation
	~	
	~		|

TR TotalTravelTime[traffic type]=
	SUM(TR Trips[mode!,trip length!,traffic type,coping type!] * TR TravelTime[mode!,trip length\
		!,traffic type]) / SUM(TR Trips[mode!,trip length!,traffic type,coping type!])
	~	
	~		|

ComparisonOfTrips[mode,trip length,traffic type]=
	(TR TotalTrips[mode,trip length,traffic type] - TR Trips Data[mode,trip length,traffic type\
		]) /
	TR Trips Data[mode,trip length,traffic type]
	~	
	~		|

TR DemandIncreasePop[trip length,traffic type,mode,coping type]=
	TR InitialTripRate[trip length,traffic type,mode] * HB PopNetIncrease[traffic type] \
		* 12 * CopingTypesDistribution[coping type]
	~	
	~		|

HB PopNetIncrease[traffic type]:HOLD BACKWARD:
	~	
	~		|

TR ModalSplitPerCT[mode,traffic type,coping type]=
	SUM( TR Trips[mode,trip length!,traffic type,coping type] * TR InitialTripLength[traffic type\
		,trip length!]) / TR TotalDistanceTravelledPerCT[traffic type, coping type]
	~	
	~		|

TR Trips Data[mode,trip length,traffic type]:RAW:
	~	
	~		|

TR BaseAtttractiveness[bicycle,trip length]=
	3 ~~|
TR BaseAtttractiveness[car,trip length]=
	2 ~~|
TR BaseAtttractiveness[public transport,trip length]=
	2.5 ~~|
TR BaseAtttractiveness[walk,trip length]=
	5 ~~|
TR BaseAtttractiveness[car passenger,trip length]=
	3
	~	
	~		|

PI StreetGreening=
	0
	~	 [0,1,0.1]
	~		|

active modes:
	bicycle, walk
	~	
	~		|

TR StreetNetworkLoad=
	SUM(TR Trips[car,trip length!,traffic type!,coping type!]) / TR AdaptedNetworkCapacity
	~	
	~		|

TR AttractivenessProfile[mode,coping type]=
	3, 2, 1, -1, -2, -3;
	3, 2, 1, 0, -1, -2;
	-3, -2, -1, 1, 3, 2;
	-3, -2, -1, 0, 2, 3;
	-3, -2, -1, 1, 3, 2;
	~	
	~		|

TR BaseValueOfTime=
	15
	~	
	~		|

TR TotalDistanceTravelledPerCT[traffic type,coping type]=
	SUM( TR Trips[mode!,trip length!,traffic type,coping type] * TR InitialTripLength[traffic type\
		,trip length!])
	~	
	~		|

TR ValueOfTimeDistinction=
	1
	~	
	~		|

TR ValueOfTimeProfile[coping type]=
	3, -2, 2, -3, -1, 1
	~	
	~		|

TR ValueOfTime[coping type]=
	TR BaseValueOfTime + TR ValueOfTimeDistinction * TR ValueOfTimeProfile[coping type]
	~	
	~		|

TR AttractivenessDistinction=
	1
	~	
	~	how the coping types distinguish from each other
	|

TR InitialTrips[mode,trip length,traffic type]=
	HB InitialPopulation[traffic type] * TR InitialTripRate[trip length,traffic type, mode\
		]
	~	
	~		|

TR TotalTrips[mode,trip length,traffic type]=
	SUM(TR Trips[mode,trip length,traffic type,coping type!])
	~	
	~		|

TR TotalTravelSpeed[mode,trip length,traffic type]=
	TR InitialTripLength[traffic type,trip length] / TR TravelTime[mode,trip length,traffic type\
		]
	~	
	~		|

TR DemandChangeRate[mode,trip length,traffic type,coping type]=
	- TR DemandElasticity * (TR GeneralisedCost[mode,trip length,traffic type,coping type\
		] - TR GeneralisedCostOfPreviousTimeStep[mode,trip length,traffic type,coping type]\
		) / 10 * TR Trips[mode,trip length,traffic type,coping type]
	~	
	~	No dividing by 12 since we are comparing to previous month (i.e. only small change \
		in generalised costs).
		!!! problematic if GC is around zero (changes sign)! Dividing by 10 \
		instead ...
	|

TR GeneralisedCostOfPreviousTimeStep[mode,trip length,traffic type,coping type]= DELAY FIXED\
		 (
	TR GeneralisedCost[mode,trip length,traffic type,coping type], TIME STEP, TR GeneralisedCost\
		[mode,trip length,traffic type,coping type])
	~	
	~		|

coping type:
	Active Antagonists, Beneficent Believers, Concerned Compliers, Doubting Distressed, \
		Empathic Engagers, Fierce Forerunners
	~	
	~		|

CopingTypesDistribution[coping type]:INTERPOLATE:
	~	
	~	corrected in v9 (sum=1)
		inial values were: 0.12, 0.16, 0.33, 0.14, 0.12, 0.13
	|

HB InitialPopulation[traffic type]=
	GET DIRECT CONSTANTS('mob_inputs.csv', ';' , 'B1' )
	~	
	~		|

TR ModeChangeRate[mode,mode2,trip length,traffic type,coping type]=
	TR ModeChangeElasticity * (TR GeneralisedCost[mode,trip length,traffic type,coping type\
		] - TR GeneralisedCost[mode2,trip length,traffic type,coping type]) * 
	IF THEN ELSE( (TR GeneralisedCost[mode2,trip length,traffic type,coping type] - TR GeneralisedCost\
		[mode,trip length,traffic type,coping type]) <0,
	MAX( TR Trips[mode,trip length,traffic type,coping type], 0),
	MAX( TR Trips[mode2,trip length,traffic type,coping type], 0))
	~	
	~		|

TR AverageTravelTime[trip length,traffic type]=
	SUM(TR Trips[mode!,trip length,traffic type,coping type!]*TR TravelTime[mode!,trip length\
		,traffic type]) /
	SUM(TR Trips[mode!,trip length,traffic type,coping type!])
	~	
	~		|

TR TravelSpeed Data[mode,trip length,traffic type]:RAW:
	~	
	~	GET VDF DATA('mob7.vdfx', 'TR InitialTravelSpeed[trip length,mode,traffic \
		type]' , 120, 1)
	|

TR AccessTime[traffic type, mode]=
	0.15, 0.1, 0.2, 0, 0;
	0.15, 0.1, 0.2, 0, 0;
	~	
	~		|

TR NonCarVelocity["non-car modes",trip length]=
	20, 20, 20;
	12, 12, 12;
	4.5, 4.5, 4.5;
	~	
	~		|

"non-car modes":
	public transport,bicycle,walk
	~	
	~		|

TR NetworkCapacity=
	1e+06
	~	
	~	All Car trips (not car-passenger)   500k
		assume that max. capacity is double (1M)
	|

TR FreeCarVelocity[traffic type]=
	40, 60
	~	
	~		|

traffic type:
	internal, origin destination
	~	
	~		|

car modes:
	car, car passenger
	~	
	~		|

TR TrafficDependency[mode]=
	1e-08, 1e-08, 0, 0, 0
	~	
	~		|

TR InitialTripRate[trip length, internal, mode]=
	GET DIRECT CONSTANTS( 'mob_inputs.csv', 'mob_inputs' , 'B4' ) ~~|
TR InitialTripRate[trip length, origin destination, mode]=
	GET DIRECT CONSTANTS( 'mob_inputs.csv', 'mob_inputs' , 'B7' )
	~	
	~		|

CL Cooling degree days=
	100
	~	
	~		|

TR PercentageOfCarOwnership= INTEG (
	TR CarOwnershipChangeRate,
		70)
	~	
	~		|

TR PercentageOfAnnualPTTickets= INTEG (
	TR AnnualPTTicketsChangeRate,
		40)
	~	
	~		|

TR AnnualPTTicketsChangeRate=
	0
	~	
	~		|

TR CarOwnershipChangeRate=
	0
	~	
	~		|

mode:
	car, car passenger, public transport, bicycle, walk
	~	
	~		|

mode2:
	car, car passenger, public transport, bicycle, walk
	~	
	~		|

TR DemandElasticity=
	0.01
	~	
	~	means: If generalised cost is raised / decreased by 10 %, there will be 1% less / \
		more trips.
		!!! decrease value to avoid fluctuations
	|

TR InitialTripLength[traffic type,trip length]=
	GET DIRECT CONSTANTS( 'mob_inputs.csv', 'mob_inputs' , 'B2' )
	~	
	~		|

TR ModeChangeElasticity=
	0.01
	~	 [0.005,0.03]
	~	Meaning: If trip with mode2 is "cheaper" by 1 EUR (generalised costs), 10% \
		will change from mode to mode2 in one year.
	|

trip length:
	short, medium, long
	~	
	~		|

