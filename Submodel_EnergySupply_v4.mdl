{UTF-8}
ES ElectricityCapacity[electricityType]:INTERPOLATE:
	~	
	~		|

ES InstalledCapacity BiomassCHP= INTEG (
	ES new biomass,
		ES HeatCapacity[Biomass CHP])
	~	
	~		|

ES InstalledCapacity DHHeatPump= INTEG (
	ES new heatpumps,
		ES HeatCapacity[DH Heat Pump])
	~	
	~		|

ES InstalledCapacity ElectricBoiler= INTEG (
	ES new electrboilers,
		ES HeatCapacity[DH Electric Boiler])
	~	
	~		|

ES HeatSupply[heatType]:INTERPOLATE:
	~	
	~		|

ES InstalledCapacity GasBoiler= INTEG (
	ES new gasboilers-ES phase out gasboilers,
		ES HeatCapacity[DH Natural Gas Boiler])
	~	
	~		|

CL PVProductivity=
	ES ElectrictitySupply[PV] / ES ElectricityCapacity[PV]
	~	
	~		|

ED CoreElectricityDemand:INTERPOLATE:
	~	
	~		|

ED CoreHeatDemand:INTERPOLATE:
	~	
	~		|

ED CoreHeatDemandIncrease=
	ED CoreHeatDemand - ED CoreHeatDemandOfPreviousTimestep
	~	
	~		|

ED CoreHeatDemandOfPreviousTimestep=
	DELAY FIXED(ED CoreHeatDemand, 1 , ED CoreElectricityDemand )
	~	
	~		|

ED DHElectricityDemand=
	ES HeatSupply heatpump * GET DATA AT TIME( ES ElDemand DH HP, 2050) / GET DATA AT TIME\
		(ES HeatSupply[DH Heat Pump], 2050) +
	ES HeatSupply electric * GET DATA AT TIME( ES ElDemand DH EB, 2050) / GET DATA AT TIME\
		(ES HeatSupply[DH Electric Boiler], 2050)
	~	
	~	depending on the supply (downscaled from 2050 data)
	|

ES new biomass=
	(GET DATA AT TIME( ES HeatCapacity[Biomass CHP], 2050) - GET DATA AT TIME( ES HeatCapacity\
		[Biomass CHP], 2019)) / 31
	~	
	~		|

ES new electrboilers=
	(GET DATA AT TIME( ES HeatCapacity[DH Electric Boiler], 2050) - GET DATA AT TIME( ES HeatCapacity\
		[DH Electric Boiler], 2019)) / 31
	~	
	~		|

ES phase out oilboilers=
	(GET DATA AT TIME( ES HeatCapacity[DH Fuel Oil Boiler], 2019) - GET DATA AT TIME( ES HeatCapacity\
		[DH Fuel Oil Boiler], 2050)) / 31
	~	
	~		|

ES new gasboilers=
	0
	~	
	~		|

electricityType:
	PV,
	Biomass CHP el,
	Waste CHP el,
	Grid Connection,
	Biomethane CHP el,
	Battery,
	Fuel Cell el,
	Fuel Oil PP,
	Biogas PP,
	Natural Gas CHP el,
	Peat CHP el
	~	
	~		|

ES ElDemand DH EB:INTERPOLATE:
	~	
	~		|

ES ElDemand DH HP:INTERPOLATE:
	~	
	~		|

ES new wasteCHP=
	(GET DATA AT TIME( ES HeatCapacity[Waste CHP], 2050) - GET DATA AT TIME( ES HeatCapacity\
		[Waste CHP], 2019)) / 31
	~	
	~		|

ES HeatSupply total=
	ES HeatSupply biomass + ES HeatSupply gas + ES HeatSupply heatpump + ES HeatSupply oil\
		 + ES HeatSupply waste
	~	
	~		|

ES ElectrictitySupply[electricityType]:INTERPOLATE:
	~	
	~		|

ES HeatCapacity[heatType]:INTERPOLATE:
	~	
	~		|

ES phase out gasboilers=
	(GET DATA AT TIME( ES HeatCapacity[DH Natural Gas Boiler], 2019) - GET DATA AT TIME(\
		 ES HeatCapacity[DH Natural Gas Boiler], 2050)) / 31
	~	
	~	assumed linear
	|

ES HeatSupply biomass=
	MIN( ES InstalledCapacity BiomassCHP * GET DATA AT TIME( ES HeatSupply[Biomass CHP],\
		 2019) /
	GET DATA AT TIME( ES HeatCapacity[Biomass CHP], 2019), ES HeatSupply[Biomass CHP])
	~	
	~	limited by
		- the capacity
		- the PI (ramp down)
		not yet considered: use for gaps if heat demand cannot be covered \
		otherwise?
	|

ES HeatSupply electric=
	ES InstalledCapacity ElectricBoiler * GET DATA AT TIME( ES HeatSupply[DH Electric Boiler\
		], 2050) /
	GET DATA AT TIME( ES HeatCapacity[DH Electric Boiler], 2050) + ES HeatSupplyGap
	~	
	~	Assumption: scaled against data, but gap covered by electric boilers
	|

ES HeatSupply gas=
	ES InstalledCapacity GasBoiler * GET DATA AT TIME( ES HeatSupply[DH Natural Gas Boiler\
		], 2019) /
	GET DATA AT TIME( ES HeatCapacity[DH Natural Gas Boiler], 2019)
	~	
	~		|

ES HeatSupply heatpump=
	ES InstalledCapacity DHHeatPump * GET DATA AT TIME( ES HeatSupply[DH Heat Pump], 2050\
		) /
	GET DATA AT TIME( ES HeatCapacity[DH Heat Pump], 2050)
	~	
	~		|

ES HeatSupply oil=
	ES InstalledCapacity OilBoiler * GET DATA AT TIME( ES HeatSupply[DH Fuel Oil Boiler]\
		, 2019) /
	GET DATA AT TIME( ES HeatCapacity[DH Fuel Oil Boiler], 2019)
	~	
	~	use all installed capacity during phase out
	|

ES InstalledCapacity WasteCHP= INTEG (
	ES new wasteCHP,
		ES HeatCapacity[Waste CHP])
	~	
	~		|

ES HeatSupply waste=
	MIN( ES InstalledCapacity WasteCHP * GET DATA AT TIME( ES HeatSupply[Waste CHP], 2019\
		) /
	GET DATA AT TIME( ES HeatCapacity[Waste CHP], 2019), ES HeatSupply[Waste CHP])
	~	
	~		|

ES HeatSupplyGap=
	IF THEN ELSE(ED CoreHeatDemand - ES HeatSupply total > 0, ED CoreHeatDemand - ES HeatSupply total\
		, 0)
	~	
	~		|

ES InstalledCapacity OilBoiler= INTEG (
	ES new oilboilers-ES phase out oilboilers,
		ES HeatCapacity[DH Fuel Oil Boiler])
	~	
	~		|

ES InitialInstalledCapacity PV=
	GET DATA AT TIME( ES ElectricityCapacity[PV], 2019)
	~	
	~		|

fossile electr:
	Fuel Oil PP,Biogas PP,Natural Gas CHP el,Peat CHP el
	~	
	~		|

ES InitialInstalledCapacity fossile=
	ES ElectricityCapacity[Fuel Oil PP] + ES ElectricityCapacity[Biogas PP] + 
	ES ElectricityCapacity[Natural Gas CHP el] + ES ElectricityCapacity[Peat CHP el]
	~	
	~		|

ES new oilboilers=
	0
	~	
	~		|

ES new heatpumps=
	(GET DATA AT TIME( ES HeatCapacity[DH Heat Pump], 2050) - GET DATA AT TIME( ES HeatCapacity\
		[DH Heat Pump], 2019)) / 31
	~	
	~		|

ES PowerProduction PV=
	ES InstalledCapacity PV * CL PVProductivity
	~	
	~		|

heatType:
	Waste CHP,
	DH Biomass Boiler,
	DH Electric Boiler,
	Electrolyzer,
	Biomass CHP,
	Fuel Cell,
	DH Heat Pump,
	Heat Storage,
	Natural Gas CHP,
	Peat CHP,
	DH Natural Gas Boiler,
	Biomethane CHP,
	DH Fuel Oil Boiler
	~	
	~		|

ED TotalElectricityDemand=
	ED CoreElectricityDemand + ED DHElectricityDemand
	~	
	~		|

ES PowerProduction total=
	ES PowerProduction fossile+ES PowerProduction hydro+ES PowerProduction PV+ES PowerProduction wind\
		 +
	ES ElectrictitySupply[Biomass CHP el] + ES ElectrictitySupply[Waste CHP el]
	~	
	~	el.supply from CHP driven from data only (=PI determined)
		dependencies on heat supply and el. prices still to be implemented
	|

ES PowerProduction fossile=
	MIN(ED TotalElectricityDemand - ES PowerProduction PV - ES PowerProduction wind - ES PowerProduction hydro\
		, ES InstalledCapacity fossile * SUM(GET DATA AT TIME(ES ElectrictitySupply[fossile electr\
		!], 2019)) / SUM(GET DATA AT TIME(ES ElectricityCapacity[fossile electr!], 2019)))
	~	
	~	Assumption: Prefernce over importing; but anyway zero after 10y
	|

CL AverageHydroInflow=
	100
	~	
	~		|

CL AverageSolarIrradiance=
	CL DNI + CL GHI
	~	
	~	to be completed
	|

CL AverageWindSpeed=
	4
	~	
	~		|

CL DNI=
	1
	~	
	~		|

CL GHI=
	1
	~	
	~		|

ES InitialInstalledCapacity hydro=
	0
	~	
	~		|

ES InitialInstalledCapacity wind=
	0
	~	
	~		|

ES WindFLH=
	CL AverageWindSpeed * ES WindCal
	~	
	~	only first approximation; might rather be  v^3?
	|

ES PowerProduction hydro=
	ES InstalledCapacity hydro * ES HydroFLH / 8760
	~	
	~	Dependency on ED TotalElectricityDemand?
	|

ES HydroCal=
	1
	~	
	~		|

ES HydroFLH=
	CL AverageHydroInflow * ES HydroCal
	~	
	~		|

ES PowerProduction wind=
	ES InstalledCapacity wind * ES WindFLH / 8760
	~	
	~	Dependency on ED TotalElectricityDemand?
	|

ES WindCal=
	1
	~	
	~		|

ES PVCal=
	1
	~	
	~		|

ES Policy=
	PI PV * PI Capacity
	~	
	~		|

ES InstalledCapacity fossile= INTEG (
	ES new fossile-ES phase out fosssile,
		ES InitialInstalledCapacity fossile)
	~	
	~	0.99 * 0.2 * ED TotalElectricityDemand
	|

ES InstalledCapacity PV= INTEG (
	ES PV increase,
		ES InitialInstalledCapacity PV)
	~	
	~	0.01 * 0.2 * ED TotalElectricityDemand
	|

PI Capacity=
	0.2
	~	
	~		|

PI PV=
	0
	~	 [0,1,0.5]
	~		|

ES PV increase=
	(GET DATA AT TIME( ES ElectricityCapacity[PV], 2050) - GET DATA AT TIME(ES ElectricityCapacity\
		[PV], 2019)) / 31
	~	
	~		|

CL AverageAirTemperature=
	20 + Time / 120
	~	
	~	initial assumption
	|

ES new fossile=
	0
	~	
	~		|

ES new hydro=
	0
	~	
	~		|

ED TotalElectricityDemand OfPreviousTimestep=
	DELAY FIXED(ED TotalElectricityDemand, TIME STEP , ED TotalElectricityDemand)
	~	
	~		|

ED TotalElectricityDemandIncrease=
	ED TotalElectricityDemand - ED TotalElectricityDemand OfPreviousTimestep
	~	
	~		|

ES ElectricityGenTotalEmissions=
	ES PowerProduction fossile * 0.55 +
	ES NetImportedElectricity * ES ImportedElectricityMixFactor
	~	
	~	EU average: 0.23kg CO2 per kWh
		Fossile average (coal, gas, oil): 0.5-0.6 kg CO2 per kWh (to be replaced vy \
		calibration variable)
		Average for Estonia:  0.4, going linear towards zero until 2050
	|

ES NetImportedElectricity=
	ED TotalElectricityDemand - ES PowerProduction total
	~	
	~	NetImportedElectricity = ImportedElectricity - ExportedElectricity
		(to be clarified if this simplification is acceptable)
	|

ES ImportedElectricityMixFactor=
	0.4 - 0.4 / 31 * (Time-2019)
	~	
	~		|

ES InstalledCapacity hydro= INTEG (
	ES new hydro,
		ES InitialInstalledCapacity hydro)
	~	
	~		|

ES InstalledCapacity wind= INTEG (
	ES new wind,
		ES InitialInstalledCapacity wind)
	~	
	~		|

ES new wind=
	0
	~	
	~		|

ES phase out fosssile=
	ES InstalledCapacity fossile / 10
	~	
	~	reduce 10% per year (slowly approaches zero)
	|

ED Electricity PeakDemand=
	ED TotalElectricityDemand / 365 / 24 * 1.5
	~	
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2050
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 2019
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

